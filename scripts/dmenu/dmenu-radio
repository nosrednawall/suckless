#!/bin/bash

CONFIG_FILE="$HOME/.config/suckless/scripts/dmenu/dmenu-radio.conf"
PLAYER="mpv"
PID_FILE="/tmp/dmenu_radio.pid"
MPD_PID_FILE="/tmp/mpd.pid"

# Função para obter valores do arquivo .conf
get_value() {
    local radio="$1"
    local field="$2"

    sed -n "/^\[$radio\]/,/^\[/p" "$CONFIG_FILE" | \
    grep "^$field =" | \
    head -1 | \
    cut -d'=' -f2- | \
    sed 's/^[[:space:]]*//; s/[[:space:]]*$//; s/^"//; s/"$//'
}

# Lista todas as rádios
get_radios() {
    grep '^\[.*\]$' "$CONFIG_FILE" | sed 's/^\[//; s/\]$//'
}

# Mata o processo do MPD se estiver rodando
kill_mpd() {
    if pgrep -x "mpd" > /dev/null; then
        pkill -x "mpd"
        echo "MPD finalizado"
    fi
}

# Verifica se há uma rádio tocando
is_playing() {
    if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        return 0
    else
        rm -f "$PID_FILE" 2>/dev/null
        return 1
    fi
}

# Pausa/Resume usando playerctl
toggle_pause() {
    playerctl --player=mpv play-pause 2>/dev/null
}

# Para a reprodução e mata o MPD
stop_radio() {
    if [[ -f "$PID_FILE" ]]; then
        kill "$(cat "$PID_FILE")" 2>/dev/null
        rm -f "$PID_FILE"
    fi

    # Mata o MPD quando o rádio fechar
    kill_mpd
}

# Toca uma rádio
play_radio() {
    local radio="$1"
    local stream_url=$(get_value "$radio" "stream")
    local tags=$(get_value "$radio" "tags")
    local site=$(get_value "$radio" "site")

    if [[ -z "$stream_url" ]]; then
        echo "Stream não encontrada para: $radio" | dmenu -p "ERRO" -l 1
        return 1
    fi

    # Para qualquer rádio tocando
    stop_radio

    # Inicia o player com suporte ao playerctl
    $PLAYER --no-video "$stream_url" > /dev/null 2>&1 &
    echo $! > "$PID_FILE"

    # Aguarda o player inicializar
    sleep 1

    # Notifica
    notify-send "🎵 Tocando agora" "$radio\n$tags" 2>/dev/null || echo "Tocando: $radio - $tags"
}

# Menu quando não há rádio tocando
main_menu_no_playing() {
    local selected=$(get_radios | dmenu -p "🎵 Selecione uma rádio" -l 10)

    if [[ -n "$selected" ]]; then
        play_radio "$selected"
    fi
}

# Menu quando há rádio tocando
main_menu_playing() {
    local current_metadata=$(playerctl --player=mpv metadata --format "{{ artist }} - {{ title }}" 2>/dev/null)
    [[ -z "$current_metadata" ]] && current_metadata="Rádio tocando"

    local options="▶️  Play/Pause\n⏹️  Stop\n📻  Trocar rádio\n🔊  Volume +10%\n🔉  Volume -10%"
    local selected=$(echo -e "$options" | dmenu -p "🎵 $current_metadata" -l 5)

    case "$selected" in
        "▶️  Play/Pause")
            toggle_pause
            sleep 0.5
            main_menu_playing
            ;;
        "⏹️  Stop")
            stop_radio
            sleep 0.5
            main_menu_no_playing
            ;;
        "📻  Trocar rádio")
            local radio_selected=$(get_radios | dmenu -p "🎵 Selecione outra rádio" -l 10)
            if [[ -n "$radio_selected" ]]; then
                play_radio "$radio_selected"
            else
                main_menu_playing
            fi
            ;;
        "🔊  Volume +10%")
            playerctl --player=mpv volume 0.1+ 2>/dev/null
            sleep 0.5
            main_menu_playing
            ;;
        "🔉  Volume -10%")
            playerctl --player=mpv volume 0.1- 2>/dev/null
            sleep 0.5
            main_menu_playing
            ;;
        *)
            exit 0
            ;;
    esac
}

# Função principal
main() {
    # Mata o MPD antes de iniciar o rádio
    kill_mpd

    if is_playing; then
        main_menu_playing
    else
        main_menu_no_playing
    fi
}

# Executa
main
